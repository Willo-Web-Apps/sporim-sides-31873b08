# =============================================================================
# SIDES Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Telegram ---
# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of Telegram user IDs with admin access
ADMIN_USER_IDS=123456789,987654321

# Your bot's username (without @)
BOT_USERNAME=sideupbot

# --- Sports APIs ---
# Free tier: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# Ball Don't Lie (NBA) — free, no key required for basic endpoints
# BALLDONTLIE_API_KEY=your_key_here  # Uncomment if you upgrade to paid plan

# --- Database ---
# SQLite (development) — no setup needed, file is created automatically
DATABASE_URL=sqlite+aiosqlite:///sides.db

# For production on Railway with PostgreSQL, use:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/sides

# --- Application ---
ENVIRONMENT=development
# ENVIRONMENT=production
