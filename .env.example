# ─────────────────────────────────────────────
# SideUp Bot (@sideupbot) — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID(s) — comma-separated — these get admin commands
ADMIN_USER_IDS=123456789

# football-data.org free API key (register at football-data.org/client/register)
FOOTBALL_DATA_API_KEY=your_football_data_key_here

# Database (SQLite for local dev, PostgreSQL URL for production)
DATABASE_URL=sqlite+aiosqlite:///sides.db

# Bot username (without @)
BOT_USERNAME=sideupbot

# Environment: development | production
ENVIRONMENT=development
