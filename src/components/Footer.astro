---
const year = new Date().getFullYear();
---
<footer style="background:oklch(0.07 0.005 145);border-top:1px solid oklch(0.14 0.009 145);padding:56px 0 32px;">
  <div style="max-width:1100px;margin:0 auto;padding:0 24px;">

    <div style="display:flex;flex-direction:column;gap:40px;">
      <div style="display:flex;flex-wrap:wrap;gap:48px;justify-content:space-between;align-items:flex-start;">

        <!-- Brand -->
        <div style="max-width:260px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
            <div style="width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,oklch(0.72 0.22 145),oklch(0.55 0.20 145));display:flex;align-items:center;justify-content:center;font-family:'Archivo Black',sans-serif;font-size:16px;color:oklch(0.09 0.006 145);">S</div>
            <span style="font-family:'Archivo Black',sans-serif;font-size:1.1rem;color:oklch(0.96 0.005 145);">Side<span style="color:oklch(0.72 0.22 145);">Up</span></span>
          </div>
          <p style="font-family:'Barlow',sans-serif;font-size:14px;color:oklch(0.42 0.007 145);line-height:1.65;margin-bottom:16px;">
            No house. Just you and them.<br/>P2P sports challenges inside Telegram.
          </p>
          <a href="https://t.me/sideupbot" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:6px;font-family:'Barlow',sans-serif;font-size:13px;font-weight:700;color:oklch(0.72 0.22 145);text-decoration:none;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8l-1.68 7.92c-.12.56-.44.7-.9.44l-2.46-1.82-1.18 1.14c-.13.13-.25.25-.5.25l.18-2.52 4.6-4.16c.2-.18-.04-.28-.3-.1L8.76 14.16 6.34 13.4c-.54-.17-.56-.54.12-.8l8.92-3.44c.44-.16.82.1.26.64z"/></svg>
            @sideupbot on Telegram
          </a>
        </div>

        <!-- Links -->
        <div style="display:flex;gap:56px;flex-wrap:wrap;">
          <div>
            <p style="font-family:'Archivo Black',sans-serif;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:oklch(0.45 0.008 145);margin-bottom:14px;">Product</p>
            <div style="display:flex;flex-direction:column;gap:10px;">
              <a href="#how-it-works" style="font-family:'Barlow',sans-serif;font-size:14px;color:oklch(0.48 0.007 145);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='oklch(0.72 0.22 145)'" onmouseout="this.style.color='oklch(0.48 0.007 145)'">How it works</a>
              <a href="#sports" style="font-family:'Barlow',sans-serif;font-size:14px;color:oklch(0.48 0.007 145);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='oklch(0.72 0.22 145)'" onmouseout="this.style.color='oklch(0.48 0.007 145)'">Supported sports</a>
              <a href="#faq" style="font-family:'Barlow',sans-serif;font-size:14px;color:oklch(0.48 0.007 145);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='oklch(0.72 0.22 145)'" onmouseout="this.style.color='oklch(0.48 0.007 145)'">FAQ</a>
            </div>
          </div>
          <div>
            <p style="font-family:'Archivo Black',sans-serif;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:oklch(0.45 0.008 145);margin-bottom:14px;">Legal</p>
            <div style="display:flex;flex-direction:column;gap:10px;">
              <a href="#" style="font-family:'Barlow',sans-serif;font-size:14px;color:oklch(0.48 0.007 145);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='oklch(0.72 0.22 145)'" onmouseout="this.style.color='oklch(0.48 0.007 145)'">Terms of Service</a>
              <a href="#" style="font-family:'Barlow',sans-serif;font-size:14px;color:oklch(0.48 0.007 145);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='oklch(0.72 0.22 145)'" onmouseout="this.style.color='oklch(0.48 0.007 145)'">Privacy Policy</a>
            </div>
          </div>
        </div>

      </div>

      <!-- Bottom -->
      <div style="padding-top:28px;border-top:1px solid oklch(0.12 0.008 145);display:flex;flex-wrap:wrap;gap:8px;justify-content:space-between;align-items:center;">
        <p style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.33 0.005 145);">
          &copy; {year} SideUp. Technology escrow platform. Not a gambling operator.
        </p>
        <p style="font-family:'Barlow',sans-serif;font-size:12px;color:oklch(0.28 0.005 145);">
          Users are responsible for compliance with local laws.
        </p>
      </div>
    </div>

  </div>
</footer>
