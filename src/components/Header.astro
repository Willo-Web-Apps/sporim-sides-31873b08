---
---
<header style="position:sticky;top:0;z-index:50;background:oklch(0.09 0.006 145 / 0.92);backdrop-filter:blur(18px) saturate(1.3);-webkit-backdrop-filter:blur(18px) saturate(1.3);border-bottom:1px solid oklch(0.18 0.010 145);">
  <div style="max-width:1100px;margin:0 auto;padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;">

    <!-- Logo -->
    <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;">
      <div style="width:34px;height:34px;border-radius:9px;background:linear-gradient(135deg,oklch(0.72 0.22 145),oklch(0.55 0.20 145));display:flex;align-items:center;justify-content:center;font-family:'Archivo Black',sans-serif;font-size:17px;color:oklch(0.09 0.006 145);flex-shrink:0;box-shadow:0 0 14px oklch(0.72 0.22 145 / 0.35);">S</div>
      <span style="font-family:'Archivo Black',sans-serif;font-size:1.15rem;color:oklch(0.96 0.005 145);letter-spacing:-0.02em;">Side<span style="color:oklch(0.72 0.22 145);">Up</span></span>
    </a>

    <!-- Nav -->
    <div style="display:flex;align-items:center;gap:4px;">
      <a href="#how-it-works" style="font-family:'Barlow',sans-serif;font-size:14px;font-weight:500;color:oklch(0.55 0.008 145);padding:8px 14px;border-radius:6px;text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='oklch(0.96 0.005 145)'" onmouseout="this.style.color='oklch(0.55 0.008 145)'">How it works</a>
      <a href="#faq" style="font-family:'Barlow',sans-serif;font-size:14px;font-weight:500;color:oklch(0.55 0.008 145);padding:8px 14px;border-radius:6px;text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='oklch(0.96 0.005 145)'" onmouseout="this.style.color='oklch(0.55 0.008 145)'">FAQ</a>
      <a
        href="https://t.me/sideupbot"
        target="_blank"
        rel="noopener"
        style="font-family:'Barlow',sans-serif;font-size:14px;font-weight:700;background:oklch(0.72 0.22 145);color:oklch(0.09 0.006 145);padding:9px 20px;border-radius:8px;text-decoration:none;margin-left:6px;display:flex;align-items:center;gap:7px;transition:background-color 0.15s,box-shadow 0.15s;"
        onmouseover="this.style.backgroundColor='oklch(0.80 0.22 145)';this.style.boxShadow='0 0 18px oklch(0.72 0.22 145 / 0.5)'"
        onmouseout="this.style.backgroundColor='oklch(0.72 0.22 145)';this.style.boxShadow='none'"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8l-1.68 7.92c-.12.56-.44.7-.9.44l-2.46-1.82-1.18 1.14c-.13.13-.25.25-.5.25l.18-2.52 4.6-4.16c.2-.18-.04-.28-.3-.1L8.76 14.16 6.34 13.4c-.54-.17-.56-.54.12-.8l8.92-3.44c.44-.16.82.1.26.64z"/></svg>
        Open @sideupbot
      </a>
    </div>

  </div>
</header>
