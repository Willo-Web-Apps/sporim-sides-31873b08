---
import Base from '../layouts/Base.astro';
---
<Base
  title="SIDES — No house. Just you and them."
  description="SIDES is a peer-to-peer sports challenge platform built inside Telegram. Challenge friends on match outcomes, lock stakes in escrow, win automatically. No bookmaker. No flaking."
>

  <!-- =====================================================================
       HERO
       ===================================================================== -->
  <section class="relative min-h-screen flex items-center overflow-hidden noise-overlay" style="background-color: oklch(0.09 0.006 145);">

    <!-- Layered gradient background — scoreboard floodlights -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <!-- Green glow — top-left primary light source -->
      <div class="animate-orb-float" style="
        position: absolute;
        top: -15%;
        left: -10%;
        width: 70vw;
        height: 70vw;
        max-width: 800px;
        max-height: 800px;
        background: radial-gradient(ellipse at 30% 30%, oklch(0.72 0.22 145 / 0.22) 0%, transparent 65%);
        filter: blur(1px);
      "></div>
      <!-- Orange ember — bottom-right secondary -->
      <div style="
        position: absolute;
        bottom: -10%;
        right: -5%;
        width: 50vw;
        height: 50vw;
        max-width: 600px;
        max-height: 600px;
        background: radial-gradient(ellipse at 70% 70%, oklch(0.64 0.22 32 / 0.16) 0%, transparent 60%);
        filter: blur(2px);
      "></div>
      <!-- Subtle top-right green edge -->
      <div style="
        position: absolute;
        top: 0;
        right: 0;
        width: 35vw;
        height: 40vh;
        background: radial-gradient(ellipse at 90% 10%, oklch(0.72 0.22 145 / 0.09) 0%, transparent 70%);
      "></div>
      <!-- Bottom fade to next section -->
      <div style="
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 180px;
        background: linear-gradient(to bottom, transparent, oklch(0.09 0.006 145));
      "></div>
    </div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Left: Copy -->
        <div>
          <!-- Badge -->
          <div class="animate-slide-up inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase mb-6" style="background-color: oklch(0.72 0.22 145 / 0.12); color: oklch(0.72 0.22 145); border: 1px solid oklch(0.72 0.22 145 / 0.25);">
            <span style="width:6px;height:6px;border-radius:50%;background:oklch(0.72 0.22 145);display:inline-block;"></span>
            Live now on Telegram
          </div>

          <!-- Headline -->
          <h1 class="animate-slide-up delay-100 font-display leading-[0.95] tracking-tight" style="font-size: clamp(2.8rem, 7vw, 5.5rem); color: oklch(0.96 0.005 145);">
            Your friend<br />
            talks big.<br />
            <span class="text-gradient-green">Make them<br />prove it.</span>
          </h1>

          <!-- Subheadline -->
          <p class="animate-slide-up delay-200 mt-6 text-lg leading-relaxed" style="color: oklch(0.65 0.010 145); max-width: 480px;">
            SIDES locks your sports challenge in escrow inside Telegram — winner gets paid automatically when the match ends. Zero flaking. Zero house edge.
          </p>

          <!-- CTAs -->
          <div class="animate-slide-up delay-300 mt-8 flex flex-wrap gap-3 items-center">
            <a href="https://t.me/sidesbot" class="btn-primary animate-pulse-glow">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8l-1.68 7.92c-.12.56-.44.7-.9.44l-2.46-1.82-1.18 1.14c-.13.13-.25.25-.5.25l.18-2.52 4.6-4.16c.2-.18-.04-.28-.3-.1L8.76 14.16 6.34 13.4c-.54-.17-.56-.54.12-.8l8.92-3.44c.44-.16.82.1.26.64z"/></svg>
              Open @sidesbot
            </a>
            <a href="#how-it-works" class="btn-ghost">See how it works</a>
          </div>

          <!-- Micro social proof -->
          <div class="animate-slide-up delay-400 mt-8 flex items-center gap-5">
            <div class="flex -space-x-2">
              <div style="width:32px;height:32px;border-radius:50%;background:oklch(0.72 0.22 145 / 0.3);border:2px solid oklch(0.09 0.006 145);display:flex;align-items:center;justify-content:center;font-size:14px;">⚽</div>
              <div style="width:32px;height:32px;border-radius:50%;background:oklch(0.64 0.22 32 / 0.3);border:2px solid oklch(0.09 0.006 145);display:flex;align-items:center;justify-content:center;font-size:14px;">🏀</div>
              <div style="width:32px;height:32px;border-radius:50%;background:oklch(0.55 0.15 280 / 0.3);border:2px solid oklch(0.09 0.006 145);display:flex;align-items:center;justify-content:center;font-size:14px;">🏆</div>
            </div>
            <p style="font-size:0.875rem;color:oklch(0.55 0.010 145);">
              Premier League · NBA · Champions League · more coming
            </p>
          </div>
        </div>

        <!-- Right: Bot UI Mockup -->
        <div class="animate-slide-up delay-200 relative flex justify-center lg:justify-end">
          <div class="relative" style="width:100%;max-width:340px;">
            <!-- Phone frame -->
            <div style="
              background: oklch(0.11 0.007 145);
              border: 1.5px solid oklch(0.20 0.010 145);
              border-radius: 24px;
              padding: 16px;
              box-shadow: 0 32px 80px oklch(0 0 0 / 0.5), 0 0 40px oklch(0.72 0.22 145 / 0.08);
            ">
              <!-- Chat header -->
              <div style="display:flex;align-items:center;gap:10px;padding-bottom:12px;border-bottom:1px solid oklch(0.20 0.010 145);margin-bottom:12px;">
                <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,oklch(0.72 0.22 145),oklch(0.60 0.20 145));display:flex;align-items:center;justify-content:center;font-weight:900;font-size:14px;color:oklch(0.09 0.006 145);font-family:'Archivo Black',sans-serif;">S</div>
                <div>
                  <div style="font-family:'Archivo Black',sans-serif;font-size:14px;color:oklch(0.96 0.005 145);">@sidesbot</div>
                  <div style="font-size:11px;color:oklch(0.72 0.22 145);">● online</div>
                </div>
              </div>

              <!-- Messages -->
              <div style="display:flex;flex-direction:column;gap:10px;font-family:'Barlow',sans-serif;font-size:13px;">

                <!-- Bot message -->
                <div style="display:flex;gap:8px;align-items:flex-end;">
                  <div style="width:26px;height:26px;border-radius:50%;background:oklch(0.72 0.22 145 / 0.2);display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">S</div>
                  <div style="background:oklch(0.14 0.009 145);border:1px solid oklch(0.20 0.010 145);border-radius:16px 16px 16px 4px;padding:10px 14px;max-width:220px;color:oklch(0.85 0.008 145);">
                    ⚽ <strong style="color:oklch(0.96 0.005 145);">Arsenal vs Man City</strong><br/>
                    <span style="color:oklch(0.55 0.010 145);font-size:12px;">Premier League · Sat 15:00</span><br/><br/>
                    Pick your side:
                  </div>
                </div>

                <!-- User choice buttons -->
                <div style="display:flex;gap:6px;margin-left:34px;flex-wrap:wrap;">
                  <div style="background:oklch(0.72 0.22 145 / 0.15);border:1.5px solid oklch(0.72 0.22 145 / 0.5);border-radius:8px;padding:6px 12px;font-size:12px;color:oklch(0.72 0.22 145);font-weight:600;">🔴 Arsenal</div>
                  <div style="background:oklch(0.14 0.009 145);border:1px solid oklch(0.20 0.010 145);border-radius:8px;padding:6px 12px;font-size:12px;color:oklch(0.65 0.010 145);">Draw</div>
                  <div style="background:oklch(0.14 0.009 145);border:1px solid oklch(0.20 0.010 145);border-radius:8px;padding:6px 12px;font-size:12px;color:oklch(0.65 0.010 145);">🔵 Man City</div>
                </div>

                <!-- User message -->
                <div style="display:flex;justify-content:flex-end;">
                  <div style="background:oklch(0.72 0.22 145 / 0.12);border:1px solid oklch(0.72 0.22 145 / 0.25);border-radius:16px 16px 4px 16px;padding:10px 14px;max-width:200px;color:oklch(0.85 0.008 145);">
                    Arsenal, <strong style="color:oklch(0.72 0.22 145);">⭐ 500 Stars</strong>
                  </div>
                </div>

                <!-- Bot confirms -->
                <div style="display:flex;gap:8px;align-items:flex-end;">
                  <div style="width:26px;height:26px;border-radius:50%;background:oklch(0.72 0.22 145 / 0.2);display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">S</div>
                  <div style="background:oklch(0.14 0.009 145);border:1px solid oklch(0.20 0.010 145);border-radius:16px 16px 16px 4px;padding:10px 14px;max-width:220px;color:oklch(0.85 0.008 145);">
                    🔒 Stakes locked in escrow.<br/>
                    <span style="color:oklch(0.55 0.010 145);font-size:12px;">Share link to challenge a friend:</span><br/>
                    <span style="color:oklch(0.72 0.22 145);font-size:12px;word-break:break-all;">t.me/sidesbot?start=ref_8f2a</span>
                  </div>
                </div>

                <!-- Winner notification -->
                <div style="display:flex;gap:8px;align-items:flex-end;">
                  <div style="width:26px;height:26px;border-radius:50%;background:oklch(0.72 0.22 145 / 0.2);display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">S</div>
                  <div style="background:oklch(0.72 0.22 145 / 0.12);border:1.5px solid oklch(0.72 0.22 145 / 0.4);border-radius:16px 16px 16px 4px;padding:10px 14px;max-width:220px;">
                    🏆 <strong style="color:oklch(0.72 0.22 145);">You won! ⭐ 980 Stars</strong> sent to your account.<br/>
                    <span style="font-size:11px;color:oklch(0.55 0.010 145);">FT: Arsenal 2–1 Man City</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Floating stat pill -->
            <div style="
              position:absolute;
              top:-16px;
              right:-20px;
              background:oklch(0.64 0.22 32);
              color:#fff;
              font-family:'Barlow',sans-serif;
              font-weight:700;
              font-size:12px;
              padding:6px 12px;
              border-radius:999px;
              white-space:nowrap;
              box-shadow:0 4px 20px oklch(0.64 0.22 32 / 0.4);
            ">🔥 Challenge open</div>

            <!-- Floating escrow pill -->
            <div style="
              position:absolute;
              bottom:-14px;
              left:-10px;
              background:oklch(0.13 0.009 145);
              border:1px solid oklch(0.72 0.22 145 / 0.3);
              color:oklch(0.72 0.22 145);
              font-family:'Barlow',sans-serif;
              font-weight:600;
              font-size:12px;
              padding:6px 12px;
              border-radius:999px;
              white-space:nowrap;
              box-shadow:0 4px 20px oklch(0 0 0 / 0.3);
            ">🔒 Funds held in escrow</div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- =====================================================================
       TRUST BAR — key stats
       ===================================================================== -->
  <section style="background-color:oklch(0.11 0.007 145);border-top:1px solid oklch(0.17 0.010 145);border-bottom:1px solid oklch(0.17 0.010 145);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="font-display text-3xl font-black text-brand" style="font-family:'Archivo Black',sans-serif;color:oklch(0.72 0.22 145);">0%</div>
          <div style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.55 0.010 145);">commission at launch</div>
        </div>
        <div>
          <div class="font-display text-3xl font-black" style="font-family:'Archivo Black',sans-serif;color:oklch(0.96 0.005 145);">P2P</div>
          <div style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.55 0.010 145);">no house, pure escrow</div>
        </div>
        <div>
          <div class="font-display text-3xl font-black" style="font-family:'Archivo Black',sans-serif;color:oklch(0.96 0.005 145);">Auto</div>
          <div style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.55 0.010 145);">result verification</div>
        </div>
        <div>
          <div class="font-display text-3xl font-black" style="font-family:'Archivo Black',sans-serif;color:oklch(0.72 0.22 145);">Inside Telegram</div>
          <div style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.55 0.010 145);">no app download needed</div>
        </div>
      </div>
    </div>
  </section>


  <!-- =====================================================================
       HOW IT WORKS
       ===================================================================== -->
  <section id="how-it-works" style="background-color:oklch(0.09 0.006 145);padding:6rem 0;">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section header -->
      <div class="text-center mb-16">
        <p style="font-family:'Barlow',sans-serif;font-size:12px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:oklch(0.72 0.22 145);margin-bottom:12px;">How it works</p>
        <h2 style="font-family:'Archivo Black',sans-serif;font-size:clamp(2rem,5vw,3.5rem);color:oklch(0.96 0.005 145);line-height:1.05;">
          Three steps.<br />No friction.
        </h2>
      </div>

      <!-- VS divider structure — the distinctive element -->
      <div class="relative">

        <!-- Step line connector (desktop) -->
        <div class="hidden md:block absolute top-16 left-0 right-0 h-px" style="background: linear-gradient(to right, transparent 5%, oklch(0.20 0.010 145) 20%, oklch(0.20 0.010 145) 80%, transparent 95%);top:52px;z-index:0;"></div>

        <div class="grid md:grid-cols-3 gap-8 relative z-10">

          <!-- Step 1 -->
          <div class="text-center">
            <div style="
              width:64px;height:64px;border-radius:50%;
              background:linear-gradient(135deg,oklch(0.72 0.22 145 / 0.15),oklch(0.72 0.22 145 / 0.05));
              border:1.5px solid oklch(0.72 0.22 145 / 0.4);
              display:flex;align-items:center;justify-content:center;
              margin:0 auto 24px;
              font-family:'Archivo Black',sans-serif;font-size:24px;
              color:oklch(0.72 0.22 145);
            ">1</div>
            <h3 style="font-family:'Archivo Black',sans-serif;font-size:1.25rem;color:oklch(0.96 0.005 145);margin-bottom:10px;">Pick your side</h3>
            <p style="font-family:'Barlow',sans-serif;font-size:15px;color:oklch(0.60 0.010 145);line-height:1.6;">
              Open @sidesbot, choose a live match — Premier League, NBA, Champions League — and pick Home, Draw, or Away.
            </p>
          </div>

          <!-- VS -->
          <div class="text-center">
            <div style="
              width:64px;height:64px;border-radius:50%;
              background:linear-gradient(135deg,oklch(0.64 0.22 32 / 0.15),oklch(0.64 0.22 32 / 0.05));
              border:1.5px solid oklch(0.64 0.22 32 / 0.4);
              display:flex;align-items:center;justify-content:center;
              margin:0 auto 24px;
              font-family:'Archivo Black',sans-serif;font-size:20px;
              color:oklch(0.64 0.22 32);
            ">2</div>
            <h3 style="font-family:'Archivo Black',sans-serif;font-size:1.25rem;color:oklch(0.96 0.005 145);margin-bottom:10px;">Lock stakes in escrow</h3>
            <p style="font-family:'Barlow',sans-serif;font-size:15px;color:oklch(0.60 0.010 145);line-height:1.6;">
              Set your amount in Telegram Stars. Share your invite link. Your friend accepts the opposite side — both stakes are locked. No one can back out.
            </p>
          </div>

          <!-- Step 3 -->
          <div class="text-center">
            <div style="
              width:64px;height:64px;border-radius:50%;
              background:linear-gradient(135deg,oklch(0.72 0.22 145 / 0.15),oklch(0.72 0.22 145 / 0.05));
              border:1.5px solid oklch(0.72 0.22 145 / 0.4);
              display:flex;align-items:center;justify-content:center;
              margin:0 auto 24px;
              font-family:'Archivo Black',sans-serif;font-size:24px;
              color:oklch(0.72 0.22 145);
            ">3</div>
            <h3 style="font-family:'Archivo Black',sans-serif;font-size:1.25rem;color:oklch(0.96 0.005 145);margin-bottom:10px;">Winner gets paid</h3>
            <p style="font-family:'Barlow',sans-serif;font-size:15px;color:oklch(0.60 0.010 145);line-height:1.6;">
              The moment the final whistle blows, SIDES confirms the result via live sports data and sends the full pot to the winner automatically. No disputes.
            </p>
          </div>

        </div>
      </div>

      <!-- Bold VS statement -->
      <div class="mt-20 text-center relative">
        <div style="
          font-family:'Archivo Black',sans-serif;
          font-size:clamp(6rem,20vw,14rem);
          line-height:1;
          background: linear-gradient(135deg, oklch(0.72 0.22 145 / 0.12), oklch(0.64 0.22 32 / 0.08));
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;
          user-select:none;
          letter-spacing:-0.04em;
        ">VS</div>
        <p style="margin-top:-2rem;font-family:'Barlow',sans-serif;font-size:18px;color:oklch(0.55 0.010 145);position:relative;z-index:2;">
          Every challenge needs two sides. That's the whole point.
        </p>
      </div>

    </div>
  </section>


  <!-- =====================================================================
       SUPPORTED SPORTS + UPCOMING MATCHES
       ===================================================================== -->
  <section id="sports" style="background-color:oklch(0.11 0.007 145);padding:6rem 0;border-top:1px solid oklch(0.17 0.010 145);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-12">
        <p style="font-family:'Barlow',sans-serif;font-size:12px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:oklch(0.64 0.22 32);margin-bottom:12px;">Supported sports</p>
        <h2 style="font-family:'Archivo Black',sans-serif;font-size:clamp(1.75rem,4vw,3rem);color:oklch(0.96 0.005 145);line-height:1.1;">
          Big matches. Bigger bragging rights.
        </h2>
        <p style="margin-top:16px;font-family:'Barlow',sans-serif;font-size:17px;color:oklch(0.60 0.010 145);max-width:520px;margin-left:auto;margin-right:auto;">
          Live challenges across the world's most-argued-about sports — with more leagues added every week.
        </p>
      </div>

      <!-- Sport cards -->
      <div class="grid md:grid-cols-3 gap-5 mb-12">

        <!-- Football -->
        <div class="card-dark p-6" style="border:1px solid oklch(0.72 0.22 145 / 0.2);background:oklch(0.12 0.009 145);">
          <div style="font-size:2.5rem;margin-bottom:12px;">⚽</div>
          <h3 style="font-family:'Archivo Black',sans-serif;font-size:1.1rem;color:oklch(0.96 0.005 145);margin-bottom:6px;">Football</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.55 0.010 145);line-height:1.5;">Premier League · Champions League · World Cup qualifiers · Serie A · Bundesliga</p>
          <div style="margin-top:12px;display:inline-block;background:oklch(0.72 0.22 145 / 0.1);color:oklch(0.72 0.22 145);font-family:'Barlow',sans-serif;font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;border:1px solid oklch(0.72 0.22 145 / 0.2);">LIVE</div>
        </div>

        <!-- Basketball -->
        <div class="card-dark p-6" style="border:1px solid oklch(0.64 0.22 32 / 0.2);background:oklch(0.12 0.009 145);">
          <div style="font-size:2.5rem;margin-bottom:12px;">🏀</div>
          <h3 style="font-family:'Archivo Black',sans-serif;font-size:1.1rem;color:oklch(0.96 0.005 145);margin-bottom:6px;">Basketball</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.55 0.010 145);line-height:1.5;">NBA · NBA Finals · EuroLeague · FIBA World Cup</p>
          <div style="margin-top:12px;display:inline-block;background:oklch(0.64 0.22 32 / 0.1);color:oklch(0.64 0.22 32);font-family:'Barlow',sans-serif;font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;border:1px solid oklch(0.64 0.22 32 / 0.2);">LIVE</div>
        </div>

        <!-- More coming -->
        <div class="card-dark p-6" style="background:oklch(0.12 0.009 145);border-style:dashed;">
          <div style="font-size:2.5rem;margin-bottom:12px;">🏆</div>
          <h3 style="font-family:'Archivo Black',sans-serif;font-size:1.1rem;color:oklch(0.96 0.005 145);margin-bottom:6px;">More coming</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.55 0.010 145);line-height:1.5;">Tennis · Ice Hockey · MMA · Cricket · F1 — vote for your league below</p>
          <div style="margin-top:12px;display:inline-block;background:oklch(0.20 0.010 145);color:oklch(0.65 0.010 145);font-family:'Barlow',sans-serif;font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;">SOON</div>
        </div>
      </div>

      <!-- Upcoming match highlights -->
      <div style="background:oklch(0.09 0.006 145);border:1px solid oklch(0.17 0.010 145);border-radius:12px;padding:24px;">
        <div style="font-family:'Barlow',sans-serif;font-size:12px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:oklch(0.55 0.010 145);margin-bottom:16px;">🔥 Hot upcoming challenges</div>
        <div style="display:flex;flex-direction:column;gap:12px;">

          <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:oklch(0.13 0.009 145);border-radius:8px;border:1px solid oklch(0.20 0.010 145);">
            <div style="display:flex;align-items:center;gap:12px;">
              <span style="font-size:20px;">⚽</span>
              <div>
                <div style="font-family:'Barlow',sans-serif;font-weight:600;font-size:14px;color:oklch(0.90 0.006 145);">Champions League Final</div>
