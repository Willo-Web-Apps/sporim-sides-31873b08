---
import Base from '../layouts/Base.astro';
import EmailCapture from '../components/EmailCapture.astro';

const G = 'oklch(0.72 0.22 145)';   // electric green
const BG = 'oklch(0.09 0.006 145)'; // near-black
const CARD = 'oklch(0.13 0.009 145)';
const CARD2 = 'oklch(0.11 0.007 145)';
const BORDER = 'oklch(0.19 0.010 145)';
const TEXT = 'oklch(0.96 0.005 145)';
const MUTED = 'oklch(0.50 0.008 145)';
const DIM = 'oklch(0.38 0.006 145)';
---
<Base title="SideUp — Challenge friends on sports. Escrow inside Telegram.">

  <!-- ===================== HERO ===================== -->
  <section style="position:relative;overflow:hidden;padding:96px 24px 80px;text-align:center;">
    <!-- Background glow orbs -->
    <div style="pointer-events:none;position:absolute;inset:0;overflow:hidden;">
      <div style="position:absolute;top:-120px;left:50%;transform:translateX(-50%);width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,oklch(0.72 0.22 145 / 0.12) 0%,transparent 70%);"></div>
      <div style="position:absolute;bottom:-80px;right:-100px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,oklch(0.64 0.22 32 / 0.07) 0%,transparent 70%);"></div>
    </div>

    <div style="position:relative;z-index:1;max-width:800px;margin:0 auto;">
      <!-- Badge -->
      <div style="display:inline-flex;align-items:center;gap:8px;background:oklch(0.72 0.22 145 / 0.12);border:1px solid oklch(0.72 0.22 145 / 0.25);border-radius:999px;padding:6px 16px;margin-bottom:32px;">
        <span style="width:7px;height:7px;border-radius:50%;background:oklch(0.72 0.22 145);display:inline-block;box-shadow:0 0 8px oklch(0.72 0.22 145 / 0.8);"></span>
        <span style="font-family:'Barlow',sans-serif;font-size:13px;font-weight:600;color:oklch(0.72 0.22 145);letter-spacing:0.03em;">LIVE ON TELEGRAM</span>
      </div>

      <!-- Headline -->
      <h1 style="font-family:'Archivo Black',sans-serif;font-size:clamp(44px,8vw,88px);line-height:1.0;letter-spacing:-0.03em;color:oklch(0.96 0.005 145);margin:0 0 24px;">
        Your friend<br>talks big.<br><em style="font-style:italic;color:oklch(0.72 0.22 145);">Make them prove it.</em>
      </h1>

      <!-- Sub -->
      <p style="font-family:'Barlow',sans-serif;font-size:clamp(17px,2.5vw,21px);color:oklch(0.62 0.009 145);line-height:1.6;max-width:560px;margin:0 auto 40px;">
        SideUp locks your sports challenge in escrow inside Telegram — winner gets paid automatically when the match ends. Zero flaking. Zero house edge.
      </p>

      <!-- CTAs -->
      <div style="display:flex;flex-wrap:wrap;gap:14px;justify-content:center;margin-bottom:64px;">
        <a
          href="https://t.me/sideupbot"
          target="_blank" rel="noopener"
          style="display:inline-flex;align-items:center;gap:8px;padding:16px 32px;background:oklch(0.72 0.22 145);color:oklch(0.09 0.006 145);font-family:'Barlow',sans-serif;font-weight:700;font-size:17px;border-radius:10px;text-decoration:none;transition:all 0.15s;box-shadow:0 0 28px oklch(0.72 0.22 145 / 0.35);"
          onmouseover="this.style.background='oklch(0.80 0.22 145)';this.style.transform='translateY(-2px)'"
          onmouseout="this.style.background='oklch(0.72 0.22 145)';this.style.transform='translateY(0)'"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8l-1.68 7.92c-.12.56-.44.7-.9.44l-2.46-1.82-1.18 1.14c-.13.13-.25.25-.5.25l.18-2.52 4.6-4.16c.2-.18-.04-.28-.3-.1L8.76 14.16 6.34 13.4c-.54-.17-.56-.54.12-.8l8.92-3.44c.44-.16.82.1.26.64z"/></svg>
          Open @sideupbot
        </a>
        <a
          href="#how-it-works"
          style="display:inline-flex;align-items:center;gap:8px;padding:16px 32px;background:transparent;color:oklch(0.96 0.005 145);font-family:'Barlow',sans-serif;font-weight:600;font-size:17px;border-radius:10px;text-decoration:none;border:1.5px solid oklch(0.72 0.22 145 / 0.35);transition:all 0.15s;"
          onmouseover="this.style.borderColor='oklch(0.72 0.22 145 / 0.7)';this.style.color='oklch(0.72 0.22 145)'"
          onmouseout="this.style.borderColor='oklch(0.72 0.22 145 / 0.35)';this.style.color='oklch(0.96 0.005 145)'"
        >
          See how it works ↓
        </a>
      </div>

      <!-- Telegram bot preview mock -->
      <div style="max-width:380px;margin:0 auto;background:oklch(0.12 0.008 145);border:1px solid oklch(0.20 0.010 145);border-radius:20px;overflow:hidden;box-shadow:0 32px 80px oklch(0 0 0 / 0.6),0 0 0 1px oklch(0.72 0.22 145 / 0.08);">
        <!-- Bot header -->
        <div style="display:flex;align-items:center;gap:12px;padding:16px 20px;border-bottom:1px solid oklch(0.17 0.009 145);background:oklch(0.10 0.007 145);">
          <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,oklch(0.72 0.22 145),oklch(0.55 0.20 145));display:flex;align-items:center;justify-content:center;font-family:'Archivo Black',sans-serif;font-size:18px;color:oklch(0.09 0.006 145);flex-shrink:0;">S</div>
          <div>
            <div style="font-family:'Barlow',sans-serif;font-weight:700;font-size:15px;color:oklch(0.96 0.005 145);">@sideupbot</div>
            <div style="font-family:'Barlow',sans-serif;font-size:12px;color:oklch(0.72 0.22 145);display:flex;align-items:center;gap:5px;">
              <span style="width:6px;height:6px;border-radius:50%;background:oklch(0.72 0.22 145);display:inline-block;"></span>
              online
            </div>
          </div>
        </div>
        <!-- Messages -->
        <div style="padding:20px 16px;display:flex;flex-direction:column;gap:10px;">
          <div style="background:oklch(0.16 0.009 145);border-radius:4px 14px 14px 14px;padding:12px 14px;max-width:88%;align-self:flex-start;">
            <p style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.96 0.005 145);margin:0;line-height:1.5;">⚽ <strong>Arsenal vs Man City</strong><br>Premier League · Sat 15:00<br><br>Pick your side:<br>🔴 Arsenal &nbsp;&nbsp; Draw &nbsp;&nbsp; 🔵 Man City</p>
          </div>
          <div style="background:oklch(0.22 0.15 145);border-radius:14px 4px 14px 14px;padding:10px 14px;max-width:70%;align-self:flex-end;">
            <p style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.96 0.005 145);margin:0;">🔴 Arsenal, ⭐ 500 Stars</p>
          </div>
          <div style="background:oklch(0.14 0.009 145);border:1px solid oklch(0.72 0.22 145 / 0.25);border-radius:4px 14px 14px 14px;padding:12px 14px;max-width:92%;align-self:flex-start;">
            <p style="font-family:'Barlow',sans-serif;font-size:12px;color:oklch(0.72 0.22 145);margin:0;line-height:1.5;">🔒 Stakes locked in escrow.<br>Share your invite link:<br><strong style="color:oklch(0.86 0.18 145);">t.me/sideupbot?start=ref_8f2a</strong></p>
          </div>
          <div style="background:oklch(0.16 0.009 145);border-radius:4px 14px 14px 14px;padding:12px 14px;max-width:88%;align-self:flex-start;">
            <p style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.96 0.005 145);margin:0;line-height:1.5;">🏆 <strong style="color:oklch(0.72 0.22 145);">You won! ⭐ 980 Stars</strong> sent to your account.<br><span style="font-size:11px;color:oklch(0.50 0.008 145);">FT: Arsenal 2–1 Man City</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== STATS BAR ===================== -->
  <div style="padding:0 24px 80px;">
    <div style="max-width:900px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1px;background:oklch(0.18 0.010 145);border-radius:16px;overflow:hidden;border:1px solid oklch(0.18 0.010 145);">
      <div style="background:oklch(0.12 0.008 145);padding:28px 24px;text-align:center;">
        <div style="font-family:'Archivo Black',sans-serif;font-size:32px;color:oklch(0.72 0.22 145);letter-spacing:-0.02em;">0%</div>
        <div style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.48 0.007 145);margin-top:4px;">Commission at launch</div>
      </div>
      <div style="background:oklch(0.12 0.008 145);padding:28px 24px;text-align:center;">
        <div style="font-family:'Archivo Black',sans-serif;font-size:32px;color:oklch(0.72 0.22 145);letter-spacing:-0.02em;">P2P</div>
        <div style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.48 0.007 145);margin-top:4px;">No house, pure escrow</div>
      </div>
      <div style="background:oklch(0.12 0.008 145);padding:28px 24px;text-align:center;">
        <div style="font-family:'Archivo Black',sans-serif;font-size:32px;color:oklch(0.72 0.22 145);letter-spacing:-0.02em;">Auto</div>
        <div style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.48 0.007 145);margin-top:4px;">Result verification</div>
      </div>
      <div style="background:oklch(0.12 0.008 145);padding:28px 24px;text-align:center;">
        <div style="font-family:'Archivo Black',sans-serif;font-size:32px;color:oklch(0.72 0.22 145);letter-spacing:-0.02em;">⭐</div>
        <div style="font-family:'Barlow',sans-serif;font-size:13px;color:oklch(0.48 0.007 145);margin-top:4px;">Telegram Stars</div>
      </div>
    </div>
  </div>

  <!-- ===================== HOW IT WORKS ===================== -->
  <section id="how-it-works" style="padding:80px 24px;border-top:1px solid oklch(0.14 0.009 145);">
    <div style="max-width:900px;margin:0 auto;text-align:center;">
      <div style="display:inline-block;font-family:'Barlow',sans-serif;font-size:12px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:oklch(0.72 0.22 145);margin-bottom:16px;">How it works</div>
      <h2 style="font-family:'Archivo Black',sans-serif;font-size:clamp(32px,6vw,56px);line-height:1.05;letter-spacing:-0.02em;color:oklch(0.96 0.005 145);margin:0 0 16px;">Three steps.<br><em style="color:oklch(0.72 0.22 145);font-style:italic;">No friction.</em></h2>
      <p style="font-family:'Barlow',sans-serif;font-size:18px;color:oklch(0.55 0.008 145);max-width:520px;margin:0 auto 64px;line-height:1.6;">From challenge to payout in minutes. No apps, no wallets — just Telegram.</p>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;text-align:left;">
        <!-- Step 1 -->
        <div style="background:oklch(0.12 0.008 145);border:1px solid oklch(0.19 0.010 145);border-radius:16px;padding:32px 28px;position:relative;overflow:hidden;">
          <div style="position:absolute;top:20px;right:24px;font-family:'Archivo Black',sans-serif;font-size:72px;line-height:1;color:oklch(0.72 0.22 145 / 0.08);pointer-events:none;user-select:none;">1</div>
          <div style="width:48px;height:48px;background:oklch(0.72 0.22 145 / 0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:20px;">⚽</div>
          <h3 style="font-family:'Archivo Black',sans-serif;font-size:20px;color:oklch(0.96 0.005 145);margin:0 0 12px;letter-spacing:-0.01em;">Pick your side</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:15px;color:oklch(0.52 0.008 145);line-height:1.6;margin:0;">Open @sideupbot, choose a live match — Premier League, NBA, Champions League — and pick Home, Draw, or Away. Takes 30 seconds.</p>
        </div>
        <!-- Step 2 -->
        <div style="background:oklch(0.12 0.008 145);border:1px solid oklch(0.19 0.010 145);border-radius:16px;padding:32px 28px;position:relative;overflow:hidden;">
          <div style="position:absolute;top:20px;right:24px;font-family:'Archivo Black',sans-serif;font-size:72px;line-height:1;color:oklch(0.72 0.22 145 / 0.08);pointer-events:none;user-select:none;">2</div>
          <div style="width:48px;height:48px;background:oklch(0.72 0.22 145 / 0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:20px;">🔒</div>
          <h3 style="font-family:'Archivo Black',sans-serif;font-size:20px;color:oklch(0.96 0.005 145);margin:0 0 12px;letter-spacing:-0.01em;">Lock stakes in escrow</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:15px;color:oklch(0.52 0.008 145);line-height:1.6;margin:0;">Set your amount in Telegram Stars. Share your invite link. Your friend accepts the opposite side — both stakes are locked. No one can back out.</p>
        </div>
        <!-- Step 3 -->
        <div style="background:oklch(0.12 0.008 145);border:1px solid oklch(0.72 0.22 145 / 0.3);border-radius:16px;padding:32px 28px;position:relative;overflow:hidden;box-shadow:0 0 32px oklch(0.72 0.22 145 / 0.08);">
          <div style="position:absolute;top:20px;right:24px;font-family:'Archivo Black',sans-serif;font-size:72px;line-height:1;color:oklch(0.72 0.22 145 / 0.10);pointer-events:none;user-select:none;">3</div>
          <div style="width:48px;height:48px;background:oklch(0.72 0.22 145 / 0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:20px;">🏆</div>
          <h3 style="font-family:'Archivo Black',sans-serif;font-size:20px;color:oklch(0.96 0.005 145);margin:0 0 12px;letter-spacing:-0.01em;">Winner gets paid</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:15px;color:oklch(0.52 0.008 145);line-height:1.6;margin:0;">The moment the final whistle blows, SideUp confirms the result via live sports API and sends the full pot to the winner automatically. No disputes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FEATURES ===================== -->
  <section id="features" style="padding:80px 24px;background:oklch(0.10 0.007 145);">
    <div style="max-width:900px;margin:0 auto;text-align:center;">
      <div style="display:inline-block;font-family:'Barlow',sans-serif;font-size:12px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:oklch(0.72 0.22 145);margin-bottom:16px;">Why SideUp</div>
      <h2 style="font-family:'Archivo Black',sans-serif;font-size:clamp(32px,6vw,56px);line-height:1.05;letter-spacing:-0.02em;color:oklch(0.96 0.005 145);margin:0 0 16px;">No house edge.<br><em style="color:oklch(0.72 0.22 145);font-style:italic;">No bookmaker.</em><br>Just escrow.</h2>
      <p style="font-family:'Barlow',sans-serif;font-size:18px;color:oklch(0.55 0.008 145);max-width:600px;margin:0 auto 56px;line-height:1.6;">We hold stakes like PayPal holds a payment — and release them automatically when a public sports result is confirmed.</p>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;text-align:left;">
        <div style="background:oklch(0.13 0.009 145);border:1px solid oklch(0.19 0.010 145);border-radius:14px;padding:28px 24px;">
          <div style="font-size:28px;margin-bottom:16px;">🔒</div>
          <h3 style="font-family:'Archivo Black',sans-serif;font-size:17px;color:oklch(0.96 0.005 145);margin:0 0 10px;">Funds locked at accept</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:14px;color:oklch(0.50 0.008 145);line-height:1.6;margin:0;">Both parties lock stakes before the match starts. Nobody can back out once the game is live.</p>
        </div>
        <div style="background:oklch(0.13 0.009 145);border:1px solid oklch(0.19 0.010 145);border-radius:14px;padding:28px 24px;">
          <div style="font-size:28px;margin-bottom:16px;">⚡</div>
          <h3 style="font-family:'Archivo Black',sans-serif;font-size:17px;color:oklch(0.96 0.005 145);margin:0 0 10px;">Instant auto-payout</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:14px;color:oklch(0.50 0.008 145);line-height:1.6;margin:0;">Results from live football-data.org and balldontlie.io APIs. No manual review. No delays. No disputes.</p>
        </div>
        <div style="background:oklch(0.13 0.009 145);border:1px solid oklch(0.19 0.010 145);border-radius:14px;padding:28px 24px;">
          <div style="font-size:28px;margin-bottom:16px;">⭐</div>
          <h3 style="font-family:'Archivo Black',sans-serif;font-size:17px;color:oklch(0.96 0.005 145);margin:0 0 10px;">Telegram Stars only</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:14px;color:oklch(0.50 0.008 145);line-height:1.6;margin:0;">No credit cards, no crypto wallets, no KYC. Uses Telegram's native payment layer — already on your phone.</p>
        </div>
        <div style="background:oklch(0.13 0.009 145);border:1px solid oklch(0.19 0.010 145);border-radius:14px;padding:28px 24px;">
          <div style="font-size:28px;margin-bottom:16px;">👥</div>
          <h3 style="font-family:'Archivo Black',sans-serif;font-size:17px;color:oklch(0.96 0.005 145);margin:0 0 10px;">Two modes</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:14px;color:oklch(0.50 0.008 145);line-height:1.6;margin:0;">Challenge a specific friend with a private link, or post to The Market — an open list anyone can accept.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== SPORTS ===================== -->
  <section id="sports" style="padding:80px 24px;border-top:1px solid oklch(0.14 0.009 145);">
    <div style="max-width:900px;margin:0 auto;text-align:center;">
      <div style="display:inline-block;font-family:'Barlow',sans-serif;font-size:12px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:oklch(0.72 0.22 145);margin-bottom:16px;">Supported sports</div>
      <h2 style="font-family:'Archivo Black',sans-serif;font-size:clamp(32px,6vw,56px);line-height:1.05;letter-spacing:-0.02em;color:oklch(0.96 0.005 145);margin:0 0 56px;">Big matches.<br><em style="color:oklch(0.72 0.22 145);font-style:italic;">Bigger bragging rights.</em></h2>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;text-align:left;">
        <div style="background:oklch(0.12 0.008 145);border:1px solid oklch(0.19 0.010 145);border-radius:16px;padding:32px 28px;position:relative;">
          <div style="position:absolute;top:20px;right:20px;background:oklch(0.72 0.22 145);color:oklch(0.09 0.006 145);font-family:'Barlow',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.1em;padding:4px 10px;border-radius:999px;">LIVE</div>
          <div style="font-size:40px;margin-bottom:16px;">⚽</div>
          <h3 style="font-family:'Archivo Black',sans-serif;font-size:20px;color:oklch(0.96 0.005 145);margin:0 0 10px;">Football</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:14px;color:oklch(0.50 0.008 145);line-height:1.6;margin:0;">Premier League · Champions League · World Cup · Serie A · Bundesliga</p>
        </div>
        <div style="background:oklch(0.12 0.008 145);border:1px solid oklch(0.19 0.010 145);border-radius:16px;padding:32px 28px;position:relative;">
          <div style="position:absolute;top:20px;right:20px;background:oklch(0.72 0.22 145);color:oklch(0.09 0.006 145);font-family:'Barlow',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.1em;padding:4px 10px;border-radius:999px;">LIVE</div>
          <div style="font-size:40px;margin-bottom:16px;">🏀</div>
          <h3 style="font-family:'Archivo Black',sans-serif;font-size:20px;color:oklch(0.96 0.005 145);margin:0 0 10px;">Basketball</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:14px;color:oklch(0.50 0.008 145);line-height:1.6;margin:0;">NBA · NBA Finals · EuroLeague · FIBA World Cup</p>
        </div>
        <div style="background:oklch(0.12 0.008 145);border:1px solid oklch(0.19 0.010 145);border-radius:16px;padding:32px 28px;position:relative;">
          <div style="position:absolute;top:20px;right:20px;background:oklch(0.35 0.010 145);color:oklch(0.75 0.010 145);font-family:'Barlow',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.1em;padding:4px 10px;border-radius:999px;">SOON</div>
          <div style="font-size:40px;margin-bottom:16px;">🏆</div>
          <h3 style="font-family:'Archivo Black',sans-serif;font-size:20px;color:oklch(0.96 0.005 145);margin:0 0 10px;">More coming</h3>
          <p style="font-family:'Barlow',sans-serif;font-size:14px;color:oklch(0.50 0.008 145);line-height:1.6;margin:0;">Tennis · Ice Hockey · MMA · Cricket · F1 — vote for your league below</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== UPCOMING EVENTS ===================== -->
  <section id="events" style="padding:0 24px 80px;">
    <div style="max-width:900px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:40px;">
        <div style="display:inline-block;font-family:'Barlow',sans-serif;font-size:12px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:oklch(0.72 0.22 145);margin-bottom:12px;">Upcoming events</div>
        <h2 style="font-family:'Archivo Black',sans-serif;font-size:clamp(28px,5vw,44px);color:oklch(0.96 0.005 145);margin:0;">🔥 Hot upcoming challenges</h2>
      </div>

      <div style="display:flex;flex-direction:column;gap:12px;">
        <div style="background:oklch(0.12 0.008 145);border:1px solid oklch(0.72 0.22 145 / 0.25);border-radius:14px;padding:20px 24px;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:16px;">
