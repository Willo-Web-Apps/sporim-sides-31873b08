---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SIDES — No house. Just you and them.",
  description = "SIDES is a peer-to-peer sports challenge platform built inside Telegram. Challenge friends on match outcomes, lock equal stakes in escrow via Telegram Stars, and the winner is paid automatically. No bookmaker. No flaking. Zero house edge."
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const siteUrl = Astro.site?.href ?? '';

const orgSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "SIDES",
  "description": "Peer-to-peer sports challenge platform inside Telegram. Lock stakes in escrow, winner paid automatically. No bookmaker.",
  "url": siteUrl,
}).replace(/</g, '\\u003c');
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#0B0F0E" />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={orgSchema}></script>
  </head>
  <body class="min-h-screen flex flex-col font-body antialiased" style="background-color:oklch(0.09 0.006 145);color:oklch(0.96 0.005 145);">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
